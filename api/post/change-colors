type\":\"code\"}],\"text\":\"#1a4a4a\"},{\"type\":\"text\",\"text\":\" | \"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"#292e42\"},{\"type\":\"text\",\"text\":\" | \"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"border-border\"},{\"type\":\"text\",\"text\":\" |\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"| 悬停背景 | \"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"rgba(107,153,153,0.1)\"},{\"type\":\"text\",\"text\":\" | \"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"rgba(74,158,255,0.1)\"},{\"type\":\"text\",\"text\":\" | \"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"hover:bg-selection\"},{\"type\":\"text\",\"text\":\" |\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"修复后整个页面应该统一为深蓝色主题。\"}]},{\"type\":\"paragraph\"}]}","title":"change colors","tags":[],"updateTime":1770442347655,"createTime":1770442346412,"draft":false,"intro":" header 部分是**绿色**#0a2e2e 青绿色），但 layout.astro 已经改成深蓝色了。这说明 index.scss 里的样式覆盖了 layout.astro 的设置。","html":"<h1 level=\"1\" id=\"change-colors\">change colors</h1><p> header 部分是**绿色**<code>#0a2e2e</code> 青绿色），但 <code>layout.astro</code> 已经改成深蓝色了。这说明 <code>index.scss</code> 里的样式覆盖了 <code>layout.astro</code> 的设置。</p><p>问题根源在 <code>index.scss</code>：</p><p>```scss</p><p>header {</p><p>  background-color: #0a2e2e;  // ★ 这里是绿色！</p><p>  border-bottom: 1px solid #1a4a4a;</p><p>}</p><p>```</p><p>---</p><p>## Step-by-Step 修复指南</p><p>### Step 1: 修复 <code>index.scss</code>（绿色 → 深蓝色）</p><p>把 <code>index(1).scss</code> 里的绿色全部改成深蓝色：</p><p>```scss</p><p>html {</p><p>  scroll-behavior: smooth;</p><p>}</p><p>/* 强制深蓝色 header */</p><p>header {</p><p>  position: sticky;</p><p>  top: 0;</p><p>  z-index: 20;</p><p>  background-color: #1e2030;  // ★ 改：#0a2e2e → #1e2030</p><p>  border-bottom: 1px solid #292e42;  // ★ 改：#1a4a4a → #292e42</p><p>}</p><p>::-webkit-scrollbar {</p><p>  width: 6px;</p><p>  height: 6px;</p><p>  background-color: transparent;</p><p>}</p><p>::-webkit-scrollbar-track {</p><p>  background: transparent;</p><p>}</p><p>::-webkit-scrollbar-thumb {</p><p>  background-color: rgba(59, 66, 97, 0.5);  // ★ 改：rgba(92, 138, 138, 0.3) → 深蓝</p><p>  border-radius: 3px;</p><p>  </p><p>  &amp;:hover {</p><p>    background-color: rgba(86, 95, 137, 0.7);  // ★ 改：rgba(92, 138, 138, 0.5) → 深蓝</p><p>  }</p><p>}</p><p>hr {</p><p>  border-color: #292e42;  // ★ 改：#1a4a4a → #292e42</p><p>  border-style: dashed;</p><p>  border-width: 1px 0 0 0;</p><p>  margin: 1.5rem 0;</p><p>}</p><p>// 按钮样式 - 深蓝色主题</p><p>.buttoned {</p><p>  @apply px-3 py-1.5 rounded flex items-center justify-center gap-2 transition-all text-sm;</p><p>  background-color: rgba(74, 158, 255, 0.1);  // ★ 改：rgba(107, 153, 153, 0.1) → 蓝色</p><p>  color: #7aa2f7;  // ★ 改：#8cbaba → #7aa2f7</p><p>  border: 1px solid #292e42;  // ★ 改：#1a4a4a → #292e42</p><p>  &amp;:disabled {</p><p>    @apply opacity-50 cursor-not-allowed;</p><p>  }</p><p>  &amp;:not(:disabled) {</p><p>    &amp;:active {</p><p>      background-color: rgba(74, 158, 255, 0.2);  // ★ 改：绿色 → 蓝色</p><p>    }</p><p>    &amp;:not(:active):hover {</p><p>      background-color: rgba(74, 158, 255, 0.15);  // ★ 改：绿色 → 蓝色</p><p>      border-color: #4a9eff;  // ★ 改：#5c8a8a → #4a9eff</p><p>    }</p><p>  }</p><p>}</p><p>.text-button {</p><p>  @apply px-2 py-1 rounded flex items-center justify-center gap-2 transition-all text-sm;</p><p>  color: #565f89;  // ★ 改：#8cbaba → #565f89</p><p>  </p><p>  &amp;:hover {</p><p>    background-color: rgba(74, 158, 255, 0.1);  // ★ 改：绿色 → 蓝色</p><p>    color: #c8d3f5;  // ★ 改：#e0e0e0 → #c8d3f5</p><p>  }</p><p>  </p><p>  &amp;:active {</p><p>    background-color: rgba(74, 158, 255, 0.2);  // ★ 改：绿色 → 蓝色</p><p>  }</p><p>}</p><p>// loading</p><p>div[data-modal-loading] {</p><p>  position: relative;</p><p>  &amp;::before {</p><p>    @apply absolute w-full h-full top-0 left-0 bg-bg bg-opacity-90;</p><p>    content: &apos;&apos;;</p><p>    background-size: 24px;</p><p>    background-image: icon(&apos;i-svg-spinners:ring-resize&apos;);</p><p>    background-position: center;</p><p>    background-repeat: no-repeat;</p><p>    pointer-events: all;</p><p>  }</p><p>}</p><p>div[data-modal-loading=&quot;false&quot;] {</p><p>  &amp;::before {</p><p>    content: none;</p><p>  }</p><p>}</p><p>// transition</p><p>.fade-enter-active,</p><p>.fade-leave-active {</p><p>  transition: opacity 0.25s ease;</p><p>}</p><p>.fade-enter-from,</p><p>.fade-leave-to {</p><p>  opacity: 0;</p><p>}</p><p>// page</p><p>[data-page-draft]:not([data-page-draft=&quot;verified&quot;]) {</p><p>  display: none;</p><p>  visibility: hidden;</p><p>}</p><p>[data-page-draft] {</p><p>  .page-title {</p><p>    position: relative;</p><p>  }</p><p>  .page-title::after {</p><p>    content: &apos;draft&apos;;</p><p>    @apply bg-yellow-200 dark:bg-yellow rounded mx-1 px-2 py-1 text-xs align-super;</p><p>    display: none;</p><p>  }</p><p>}</p><p>// Selection styling - 深蓝色主题</p><p>::selection {</p><p>  background-color: rgba(74, 158, 255, 0.3);  // ★ 改：绿色 → 蓝色</p><p>  color: #c8d3f5;  // ★ 改：#e0e0e0 → #c8d3f5</p><p>}</p><p>```</p><p>---</p><p>### Step 2: 确认 <code>uno.config.ts</code> 使用深蓝色（已正确）</p><p>你的 <code>uno.config(1).ts</code> 已经是深蓝色了，确认 <code>theme: themes.light</code> 改成 <code>theme: themes.dark</code>：</p><p>```typescript</p><p>export default defineConfig({</p><p>  transformers: [transformerDirectives({ enforce: &quot;pre&quot; })],</p><p>  presets: [</p><p>    presetUno({</p><p>      dark: &quot;class&quot;,  // ★ 改：&quot;media&quot; → &quot;class&quot;</p><p>    }),</p><p>    presetTheme({</p><p>      theme: {</p><p>        dark: themes.dark,</p><p>      },</p><p>    }),</p><p>    presetIcons({</p><p>      autoInstall: true,</p><p>    }),</p><p>  ],</p><p>  theme: themes.dark,  // ★ 改：themes.light → themes.dark</p><p>  content: {</p><p>    filesystem: [&quot;src/**/*.tsx&quot;, &quot;src/**/*.astro&quot;],  // ★ 添加 astro</p><p>  }</p><p>});</p><p>```</p><p>---</p><p>### Step 3: 简化 <code>layout.astro</code>（删除重复样式）</p><p><code>layout.astro</code> 的 <code>&lt;style is:global&gt;</code> 和 <code>index.scss</code> 重复了，简化它：</p><p>```astro</p><p>---</p><p>import &quot;@/index.scss&quot;;  // 所有样式从这里加载</p><p>import Auth from &quot;@/components/Auth/index.astro&quot;;</p><p>import Footer from &quot;@/components/Footer.astro&quot;;</p><p>import config from &quot;urodele.config&quot;;</p><p>interface Props {</p><p>  title?: string;</p><p>  description?: string;</p><p>  footer?: boolean;</p><p>}</p><p>const { title, description, footer = true } = Astro.props;</p><p>---</p><p>&lt;!doctype html&gt;</p><p>&lt;html lang=&quot;zh-CN&quot; class=&quot;dark&quot;&gt;</p><p>  &lt;head&gt;</p><p>    &lt;meta charset=&quot;UTF-8&quot; /&gt;</p><p>    &lt;link rel=&quot;apple-touch-icon-precomposed&quot; sizes=&quot;144x144&quot; href=&quot;/favicon.png&quot; /&gt;</p><p>    &lt;meta name=&quot;apple-mobile-web-app-capable&quot; content=&quot;yes&quot; /&gt;</p><p>    &lt;meta name=&quot;mobile-web-app-capable&quot; content=&quot;yes&quot; /&gt;</p><p>    &lt;meta name=&quot;apple-mobile-web-app-status-bar-style&quot; content=&quot;black-translucent&quot; /&gt;</p><p>    &lt;meta name=&quot;apple-mobile-web-app-title&quot; content={config.head.brand} /&gt;</p><p>    &lt;meta name=&quot;msapplication-TileColor&quot; content=&quot;#1e2030&quot; /&gt;</p><p>    &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width,initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover&quot; /&gt;</p><p>    &lt;meta name=&quot;description&quot; content={description ?? config.head.description} /&gt;</p><p>    &lt;link rel=&quot;icon&quot; href=&quot;/favicon.ico&quot; /&gt;</p><p>    &lt;title&gt;{[config.head.brand, title].filter(Boolean).reverse().join(&quot; | &quot;)}&lt;/title&gt;</p><p>  &lt;/head&gt;</p><p>  &lt;body class=&quot;min-h-screen bg-bg text-text&quot;&gt;</p><p>    &lt;header class=&quot;flex justify-between items-center px-4 py-3 border-b border-border&quot;&gt;</p><p>      &lt;a href=&quot;/&quot; class=&quot;text-lg font-semibold tracking-tight hover:opacity-80 transition-opacity text-text&quot;&gt;</p><p>        {config.head.brand}</p><p>      &lt;/a&gt;</p><p>      &lt;div class=&quot;flex items-center gap-3&quot;&gt;</p><p>        &lt;slot name=&quot;operations&quot; /&gt;</p><p>        &lt;Auth /&gt;</p><p>      &lt;/div&gt;</p><p>    &lt;/header&gt;</p><p>    </p><p>    &lt;slot /&gt;</p><p>    </p><p>    {footer &amp;&amp; &lt;Footer /&gt;}</p><p>  &lt;/body&gt;</p><p>&lt;/html&gt;</p><p>```</p><p>---</p><p>### Step 4: 修复 <code>Home.astro</code>（使用 UnoCSS 类）</p><p>用 UnoCSS 的类代替硬编码颜色，确保一致性：</p><p>```astro</p><p>---</p><p>import Layout from &quot;../layouts/Layout.astro&quot;;</p><p>import Pagination from &quot;../components/Pagination.astro&quot;;</p><p>import type { ShortPageData } from &quot;../shared/type&quot;;</p><p>import config from &quot;urodele.config&quot;;</p><p>interface Props {</p><p>  posts: ShortPageData[];</p><p>  page: number;</p><p>  pages: number;</p><p>}</p><p>const { posts, page, pages } = Astro.props;</p><p>const tags = [&apos;ai&apos;, &apos;Urodele&apos;, &apos;vibecoding&apos;, &apos;essay&apos;, &apos;tech&apos;, &apos;knowledge&apos;, &apos;travel&apos;, &apos;poem&apos;, &apos;workflow&apos;];</p><p>function formatDate(dateStr: string) {</p><p>  return new Date(dateStr).toISOString().split(&apos;T&apos;)[0];</p><p>}</p><p>---</p><p>&lt;Layout title={config.head.title}&gt;</p><p>  &lt;!-- ★ 使用 UnoCSS 类 --&gt;</p><p>  &lt;header class=&quot;text-center py-8 border-b border-border&quot;&gt;</p><p>    &lt;h1 class=&quot;text-2xl font-semibold text-text mb-2 tracking-tight&quot;&gt;Less is more&lt;/h1&gt;</p><p>    &lt;p class=&quot;text-comment text-sm italic max-w-md mx-auto&quot;&gt;因一念有无故空灭而仿佛无处可逃。由此心无放逸不失众善。&lt;/p&gt;</p><p>  &lt;/header&gt;</p><p>  </p><p>  &lt;main&gt;</p><p>    &lt;div class=&quot;content&quot;&gt;</p><p>      &lt;h2 class=&quot;text-lg font-semibold text-text mt-6 mb-4 pb-2 border-b border-border&quot;&gt;Most recent posts&lt;/h2&gt;</p><p>      </p><p>      &lt;ul class=&quot;list-none p-0 m-0&quot;&gt;</p><p>        {</p><p>          <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"http://posts.map\">posts.map</a>((item) =&gt; (</p><p>            &lt;li class=&quot;flex items-baseline gap-6 py-1 hover:bg-selection transition-colors&quot;&gt;</p><p>              &lt;time class=&quot;font-mono text-xs text-comment whitespace-nowrap w-20&quot;&gt;{formatDate(item.createTime)}&lt;/time&gt;</p><p>              &lt;a href=<code>/post/${item.id}</code>} class=&quot;text-function text-sm hover:text-text hover:underline transition-colors&quot;&gt;</p><p>                {item.title}</p><p>              &lt;/a&gt;</p><p>            &lt;/li&gt;</p><p>          ))</p><p>        }</p><p>      &lt;/ul&gt;</p><p>      </p><p>      &lt;a href=&quot;/stream&quot; class=&quot;block mt-6 text-comment text-sm italic hover:text-function transition-colors&quot;&gt;</p><p>        查看更多碎片思考，请前往 Stream →</p><p>      &lt;/a&gt;</p><p>      </p><p>      &lt;Pagination page={page} pages={pages} /&gt;</p><p>      </p><p>      &lt;section class=&quot;mt-8 pt-6 border-t border-border text-center&quot;&gt;</p><p>        &lt;div class=&quot;flex flex-wrap justify-center gap-3&quot;&gt;</p><p>          {<a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"http://tags.map\">tags.map</a>(tag =&gt; (</p><p>            &lt;a href=<code>/tag/${encodeURIComponent(tag)}</code>} class=&quot;text-comment text-sm hover:text-function transition-colors&quot;&gt;</p><p>              #{tag}</p><p>            &lt;/a&gt;</p><p>          ))}</p><p>        &lt;/div&gt;</p><p>      &lt;/section&gt;</p><p>    &lt;/div&gt;</p><p>  &lt;/main&gt;</p><p>&lt;/Layout&gt;</p><p>```</p><p>---</p><p>### Step 5: 构建测试</p><p>```bash</p><p>npm run build</p><p>npm run preview</p><p>```</p><p>---</p><p>## 颜色对照表</p><p>| 用途 | 绿色（错） | 深蓝色（对） | UnoCSS 类 |</p><p>|------|-----------|-------------|-----------|</p><p>| 背景 | <code>#0a2e2e</code> | <code>#1e2030</code> | <code>bg-bg</code> |</p><p>| 文字 | <code>#e0e0e0</code> | <code>#c8d3f5</code> | <code>text-text</code> |</p><p>| 次要文字 | <code>#8cbaba</code> | <code>#565f89</code> | <code>text-comment</code> |</p><p>| 链接 | <code>#6b9999</code> | <code>#7aa2f7</code> | <code>text-function</code> |</p><p>| 边框 | <code>#1a4a4a</code> | <code>#292e42</code> | <code>border-border</code> |</p><p>| 悬停背景 | <code>rgba(107,153,153,0.1)</code> | <code>rgba(74,158,255,0.1)</code> | <code>hover:bg-selection</code> |</p><p>修复后整个页面应该统一为深蓝色主题。</p><p></p><script type=\"module\">const injectHtml = (root, html) => {\n  const iframe = document.createElement(\"iframe\");\n  const htmlContent = `<html><head></head><body>${html}</body></html>`;\n  iframe.style.width = \"100%\";\n  iframe.style.height = \"100%\";\n  iframe.onload = () => {\n    const doc = iframe.contentDocument || iframe.contentWindow?.document;\n    if (!doc) {\n      return;\n    }\n    doc.open();\n    doc.write(htmlContent);\n    doc.close();\n  };\n  root.replaceChildren(iframe);\n}\n  document.querySelectorAll('.playground')?.forEach(el=>{\n    const html = el.getAttribute('data-html');\n    if (html) {\n      injectHtml(el,html);\n    }\n    const indicator = document.createElement(\"div\");\n    indicator.className = \"indicator\";\n    const showCode = document.createElement(\"div\");\n    showCode.className = \"show-code\";\n    showCode.innerText = \"code\";\n    showCode.onclick = () => {\n      el.parentElement.classList.remove(\"preview-only\");\n    };\n    const showPreview = document.createElement(\"div\");\n    showPreview.className = \"show-preview\";\n    showPreview.innerText = \"preview\";\n    showPreview.onclick = () => {\n      el.parentElement.classList.add(\"preview-only\");\n    };\n    indicator.appendChild(showCode);\n    indicator.appendChild(showPreview);\n    el.parentElement.appendChild(indicator);\n    if (window.screen.width < 768) {\n      showPreview.click();\n    }\n  });</script>","id":"change-colors","path":"/posts/change-colors.json"}